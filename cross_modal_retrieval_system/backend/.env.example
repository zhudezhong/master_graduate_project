APP_NAME=Cross Modal Retrieval API
API_PREFIX=/api/v1
DEBUG=false

MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_PRODUCTS=scph_items
MILVUS_COLLECTION_MIH=mih_items
MILVUS_PARTITION_NAME=p_default
MILVUS_CONSISTENCY=Bounded
MILVUS_CONNECT_RETRIES=30
MILVUS_CONNECT_RETRY_INTERVAL_SECONDS=2.0

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:29092
KAFKA_PRODUCT_TOPIC=product_ingest
KAFKA_CONSUMER_GROUP=retrieval_system
INGEST_CONSUME_ENABLED=true
INGEST_CONSUME_MAX_MESSAGES=100
INGEST_CONSUME_TIMEOUT_SECONDS=10
INGEST_CONSUME_INTERVAL_SECONDS=300

HASH_BITS=64
TOPK_DEFAULT=20
FEATURE_DIM_IMAGE=512
FEATURE_DIM_TEXT=768
TEXT_MODEL_NAME=shibing624/text2vec-base-chinese

USE_MOCK_FEATURE_EXTRACTOR=false
CATEGORY_TAXONOMY_DB_PATH=data/category_taxonomy.db

MBE_STREAM_ENABLED=true
MBE_STREAM_DATA_PATH=data/MBE_test.shuffled.jsonl
MBE_STREAM_BATCH_SIZE=8
MBE_STREAM_INTERVAL_SECONDS=2.0
MBE_STREAM_MAX_RECORDS=0
MBE_STREAM_LOOP=true
